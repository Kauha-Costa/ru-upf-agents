# Copie este arquivo para ".env" e preencha com seus valores reais.
# O .env nunca deve ser commitado (já está no .gitignore).

# Token do bot, obtido com o @BotFather no Telegram
TELEGRAM_BOT_TOKEN=

# URL fixa do Google Forms de reserva do RU
FORMS_URL=https://docs.google.com/forms/d/e/1FAIpQLScxJSGzH0D-t4UqvxDt1C07tytcSkptaCRWWr2y1d4weNhhuQ/viewform

# Host do Ollama (padrão local)
OLLAMA_HOST=http://localhost:11434

# Modelos locais usados pelos agentes
LLM_MODEL=llama3.1:8b
VISION_MODEL=llava:7b
EMBED_MODEL=nomic-embed-text
